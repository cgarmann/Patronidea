{
  "name": "share-idea-functions",
  "description": "Smart Engine Cloud Functions for Share Your Idea!",
  "scripts": {
    "serve": "firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "test": "npm run test:functions && npm run test:rules",
    "test:rules": "firebase emulators:exec --config ../firebase.json --only firestore \"jest test/firestore.rules.test.js\"",
    "test:functions": "jest test/functions.transitions.test.js --runInBand",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "20"
  },
  "main": "index.js",
  "dependencies": {
    "@pinecone-database/pinecone": "^7.0.0",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^7.2.5",
    "google-auth-library": "^9.15.1",
    "openai": "^4.0.0",
    "stripe": "^14.0.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "firebase": "^11.0.0",
    "firebase-functions-test": "^3.0.0",
    "firebase-tools": "^15.15.0",
    "jest": "^30.3.0"
  },
  "private": true
}
