{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "js-functions",
      "runtime": "nodejs20",
      "ignore": ["node_modules", ".git", "firebase-debug.log"]
    },
    {
      "source": "functions_python",
      "codebase": "python-smart-engine",
      "runtime": "python311",
      "ignore": [".venv", "__pycache__", "*.pyc", ".git"]
    }
  ],
  "emulators": {
    "auth": { "port": 9099 },
    "functions": { "port": 5001 },
    "firestore": { "port": 8080 },
    "ui": { "enabled": true }
  }
}
